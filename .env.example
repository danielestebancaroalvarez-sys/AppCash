# REQUIRED — Google OAuth Web client (.apps.googleusercontent.com)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# REQUIRED on Android — Google OAuth Android client (same Cloud project)
# Package: com.deco2449584.appcash
# SHA-1: from debug keystore (see README / login screen instructions)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Gemini (receipt scan) — also configurable in Settings
EXPO_PUBLIC_GEMINI_API_KEY=

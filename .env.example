# Google OAuth — required in the APK (injected via eas.json env for cloud builds)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# After creating a release APK, register this SHA-1 on the Android OAuth client:
# Package: com.deco2449584.appcash
# Release SHA-1: 5A:E2:53:7E:BA:1E:27:75:66:8F:3B:D6:11:C8:B0:73:CB:8A:92:6C
# Debug SHA-1:   5E:8F:16:06:2E:A3:CD:2C:4A:0D:54:78:76:BA:A6:F3:8C:AB:F6:25
#
# OAuth consent screen: use "In production" (or add friends as Test users) so others can sign in.

# Receipt AI — optional here; each person can paste keys in Account → Receipt AI
EXPO_PUBLIC_OPENROUTER_API_KEY=
EXPO_PUBLIC_OPENROUTER_MODEL=openrouter/free
EXPO_PUBLIC_DEEPSEEK_API_KEY=
EXPO_PUBLIC_OCRSPACE_API_KEY=
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash
EXPO_PUBLIC_NVIDIA_API_KEY=
EXPO_PUBLIC_NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-vl-8b-v1
# Legacy alias (optional) — same as EXPO_PUBLIC_NVIDIA_API_KEY, not a second key
# EXPO_PUBLIC_NVAPI_API_KEY=

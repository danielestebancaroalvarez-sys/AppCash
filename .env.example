# Google OAuth
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Receipt AI — pick one (Settings can override; stored in SecureStore)
# Recommended free: OpenRouter → https://openrouter.ai/keys
EXPO_PUBLIC_OPENROUTER_API_KEY=
# Default uses openrouter/free (auto-selects a free vision-capable model)
EXPO_PUBLIC_OPENROUTER_MODEL=openrouter/free

# DeepSeek (text only) + OCR.space for photos → https://platform.deepseek.com
EXPO_PUBLIC_DEEPSEEK_API_KEY=
EXPO_PUBLIC_OCRSPACE_API_KEY=

# Gemini (optional fallback)
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.0-flash
